---
import { screenshotGallery, type LandingScreenshot } from '../../data/landing';

type FeatureCard = {
  id: string;
  title: string;
  description: string;
  iconLabel: string;
  paths: string[];
  screenshot?: LandingScreenshot;
};

const featureCards: FeatureCard[] = [
  {
    id: 'feature-multi-datasource-title',
    title: 'Multi-datasource monitoring',
    description: 'Query Prometheus metrics, Loki logs, Tempo traces, and VictoriaMetrics data from a single interface.',
    iconLabel: 'Multi-datasource icon',
    paths: [
      'M4 6.5a8 3 0 1 0 16 0a8 3 0 1 0 -16 0',
      'M4 6.5v5a8 3 0 0 0 16 0v-5',
      'M4 11.5v5a8 3 0 0 0 16 0v-5',
    ],
    screenshot: screenshotGallery.find((s) => s.id === 'dashboard-overview'),
  },
  {
    id: 'feature-self-hosted-title',
    title: 'Self-hosted deployment',
    description: 'Run Ace in your own environment and keep full control of your data and network.',
    iconLabel: 'Self-hosted icon',
    paths: ['M12 3l9 4.5v4.7c0 5.3-3.5 8.6-9 9.8c-5.5-1.2-9-4.5-9-9.8V7.5L12 3z', 'M9 12l2 2l4-4'],
    screenshot: screenshotGallery.find((s) => s.id === 'datasource-config'),
  },
  {
    id: 'feature-grafana-title',
    title: 'Grafana dashboard import',
    description: 'Import existing Grafana JSON dashboards and start monitoring without rebuilding.',
    iconLabel: 'Grafana migration icon',
    paths: ['M4 6h9v12H4z', 'M11 9h9v12h-9z', 'M7 10h3M7 13h3M14 13h3M14 16h3'],
    screenshot: screenshotGallery.find((s) => s.id === 'query-editor'),
  },
  {
    id: 'feature-alerting-title',
    title: 'Alerting workflows',
    description: 'Create alert rules from datasource queries and investigate incidents in one place.',
    iconLabel: 'Alerting icon',
    paths: [
      'M12 4a5 5 0 0 1 5 5v3.5l1.6 2.7c.2.3 0 .8-.4.8H5.8c-.4 0-.6-.5-.4-.8L7 12.5V9a5 5 0 0 1 5-5z',
      'M10 18a2 2 0 0 0 4 0',
    ],
    screenshot: screenshotGallery.find((s) => s.id === 'alerts'),
  },
  {
    id: 'feature-sso-title',
    title: 'SSO and access control',
    description: 'Configure Google or Microsoft SSO, manage members, and apply role-based permissions.',
    iconLabel: 'SSO icon',
    paths: ['M7 11a4 4 0 1 1 0-8a4 4 0 0 1 0 8zM17 21a4 4 0 1 0 0-8a4 4 0 0 0 0 8z', 'M10.5 8.5l3 3M13.5 15.5l3-3'],
    screenshot: screenshotGallery.find((s) => s.id === 'organization-settings'),
  },
  {
    id: 'feature-themes-title',
    title: 'Light and dark themes',
    description: 'Choose themes that keep dashboards readable during day shifts and on-call sessions.',
    iconLabel: 'Themes icon',
    paths: ['M12 3a9 9 0 1 0 9 9a7 7 0 0 1-9-9z'],
    screenshot: screenshotGallery.find((s) => s.id === 'dark-theme'),
  },
];
---

<section id="features" class="section-band light-section" aria-labelledby="features-title">
  <div class="section-inner">
    <h2 id="features-title" class="m-0 text-2xl font-semibold md:text-3xl">Core features for observability teams</h2>
    <p class="mt-4 max-w-3xl text-slate-600">
      Dashboards, querying, alerting, and access control in one open-source product — no paid-only features.
    </p>
  </div>

  <!-- Carousel — full section width so peeks can bleed into padding -->
  <div class="mt-8 relative" id="feature-carousel">
    <div class="flex items-center justify-center gap-4 px-4 md:px-8">
      <!-- Prev peek -->
      <button
        id="carousel-prev"
        type="button"
        class="hidden md:block flex-shrink-0 w-[12%] cursor-pointer rounded-xl border-0 bg-transparent p-0 opacity-40 transition-opacity duration-300 hover:opacity-70"
        aria-label="Previous feature"
      >
        <img id="peek-prev" class="block h-auto w-full rounded-xl" src="" alt="" loading="lazy" decoding="async" />
      </button>

      <!-- Active slide -->
      <div class="flex-1 min-w-0 max-w-5xl">
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-lg">
          <div class="relative">
            <button
              id="carousel-active-btn"
              type="button"
              class="block w-full cursor-zoom-in border-0 bg-transparent p-0"
              aria-label="Enlarge screenshot"
            >
              <picture>
                <source id="active-webp" srcset="" type="image/webp" />
                <img
                  id="active-img"
                  class="block h-auto w-full"
                  src=""
                  alt=""
                  width="1280"
                  height="720"
                  decoding="async"
                />
              </picture>
            </button>

            <!-- Overlay arrows -->
            <button
              id="carousel-arrow-prev"
              type="button"
              class="absolute left-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-slate-900/70 text-white backdrop-blur-sm transition hover:bg-slate-900/90"
              aria-label="Previous feature"
            >
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
            </button>
            <button
              id="carousel-arrow-next"
              type="button"
              class="absolute right-3 top-1/2 -translate-y-1/2 flex h-10 w-10 items-center justify-center rounded-full bg-slate-900/70 text-white backdrop-blur-sm transition hover:bg-slate-900/90"
              aria-label="Next feature"
            >
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
            </button>
          </div>

          <!-- Caption bar -->
          <div class="border-t border-slate-200 px-6 py-4">
            {featureCards.map((feature, i) => (
              <div class:list={["carousel-caption", i === 0 ? "" : "hidden"]} data-caption={i}>
                <div class="flex items-center gap-2">
                  <svg viewBox="0 0 24 24" role="img" aria-label={feature.iconLabel} class="h-5 w-5 stroke-emerald-600" fill="none" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                    {feature.paths.map((path) => <path d={path}></path>)}
                  </svg>
                  <h3 class="m-0 text-base font-semibold text-slate-900">{feature.title}</h3>
                </div>
                <p class="m-0 mt-1 text-sm text-slate-500">{feature.description}</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Next peek -->
      <button
        id="carousel-next"
        type="button"
        class="hidden md:block flex-shrink-0 w-[12%] cursor-pointer rounded-xl border-0 bg-transparent p-0 opacity-40 transition-opacity duration-300 hover:opacity-70"
        aria-label="Next feature"
      >
        <img id="peek-next" class="block h-auto w-full rounded-xl" src="" alt="" loading="lazy" decoding="async" />
      </button>
    </div>


    <!-- Dot indicators -->
    <div class="mt-4 flex items-center justify-center gap-2" id="carousel-dots" aria-label="Feature slides">
      {featureCards.map((feature, i) => (
        <button
          type="button"
          class:list={[
            "h-2 rounded-full transition-all duration-300",
            i === 0 ? "w-6 bg-emerald-600" : "w-2 bg-slate-300 hover:bg-slate-400",
          ]}
          data-dot={i}
          aria-label={`Go to ${feature.title}`}
        />
      ))}
    </div>
  </div>
</section>

<!-- Lightbox modal -->
<div
  id="lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Enlarged screenshot"
>
  <button
    id="lightbox-close"
    type="button"
    class="absolute right-4 top-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-white/10 text-white transition hover:bg-white/20"
    aria-label="Close lightbox"
  >
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12" /></svg>
  </button>
  <picture id="lightbox-picture" class="max-h-[90vh] max-w-[90vw]">
    <source id="lightbox-source" srcset="" type="image/webp" />
    <img
      id="lightbox-img"
      class="max-h-[90vh] max-w-[90vw] rounded-lg object-contain shadow-2xl"
      src=""
      alt=""
    />
  </picture>
</div>

<script define:vars={{ features: featureCards.map(f => ({ jpg: f.screenshot?.jpg, webp: f.screenshot?.webp, alt: f.screenshot?.alt, title: f.title })) }}>
  const slides = features;
  const total = slides.length;
  let current = 0;
  let autoTimer;

  const activeImg = document.getElementById('active-img');
  const activeWebp = document.getElementById('active-webp');
  const activeBtn = document.getElementById('carousel-active-btn');
  const peekPrev = document.getElementById('peek-prev');
  const peekNext = document.getElementById('peek-next');
  const captions = document.querySelectorAll('[data-caption]');
  const dots = document.querySelectorAll('[data-dot]');

  function wrap(i) { return ((i % total) + total) % total; }

  function goTo(index) {
    current = wrap(index);
    const prev = wrap(current - 1);
    const next = wrap(current + 1);

    activeImg.src = slides[current].jpg;
    activeWebp.srcset = slides[current].webp;
    activeImg.alt = slides[current].alt;
    activeBtn.setAttribute('aria-label', 'Enlarge screenshot: ' + slides[current].title);

    peekPrev.src = slides[prev].jpg;
    peekPrev.alt = slides[prev].title;
    peekNext.src = slides[next].jpg;
    peekNext.alt = slides[next].title;

    captions.forEach(function(c, i) { c.classList.toggle('hidden', i !== current); });
    dots.forEach(function(d, i) {
      if (i === current) {
        d.className = 'h-2 w-6 rounded-full bg-emerald-600 transition-all duration-300';
      } else {
        d.className = 'h-2 w-2 rounded-full bg-slate-300 hover:bg-slate-400 transition-all duration-300';
      }
    });
  }

  function resetAuto() {
    clearInterval(autoTimer);
    autoTimer = setInterval(function() { goTo(current + 1); }, 6000);
  }

  // Init
  goTo(0);

  // Navigation — peek images, overlay arrows
  document.getElementById('carousel-prev').addEventListener('click', function() { goTo(current - 1); resetAuto(); });
  document.getElementById('carousel-next').addEventListener('click', function() { goTo(current + 1); resetAuto(); });
  document.getElementById('carousel-arrow-prev').addEventListener('click', function() { goTo(current - 1); resetAuto(); });
  document.getElementById('carousel-arrow-next').addEventListener('click', function() { goTo(current + 1); resetAuto(); });
  dots.forEach(function(dot, i) { dot.addEventListener('click', function() { goTo(i); resetAuto(); }); });
  resetAuto();

  // Lightbox
  var lightbox = document.getElementById('lightbox');
  var lightboxImg = document.getElementById('lightbox-img');
  var lightboxSource = document.getElementById('lightbox-source');

  function openLightbox() {
    lightboxSource.srcset = slides[current].webp;
    lightboxImg.src = slides[current].jpg;
    lightboxImg.alt = slides[current].alt;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  activeBtn.addEventListener('click', openLightbox);
  document.getElementById('lightbox-close').addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', function(e) { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeLightbox(); });
</script>
