---
const testimonials = [
  {
    quote:
      'We built Ace because we were tired of fighting Grafana\'s plugin ecosystem just to get basic observability working. One binary, eleven datasources, zero feature gates. That\'s the product we wanted to use ourselves.',
    name: 'Jan Hoon',
    role: 'Opensource Platform Engineering / Ace Maintainer',
  },
  {
    quote:
      'Shipping Ace with enterprise auth baked in from day one was a deliberate choice. Every team deserves SSO, RBAC, and audit logging without negotiating an enterprise contract. Open source should mean open source.',
    name: 'Dean van Zyl',
    role: 'Opensource Platform Engineering / Ace Maintainer',
  },
  {
    quote:
      'Tell us about your Ace journey to be featured here.',
    name: 'You?',
    role: 'Future Ace User / Platform Engineering Enthusiast',
    placeholder: true,
  },
];
---

<section id="testimonials" class="section-band alt-section" aria-labelledby="testimonials-title">
  <div class="section-inner">
    <p class="m-0 font-[family-name:var(--font-mono)] text-xs uppercase tracking-[0.06em] text-[var(--color-primary)]">Testimonials</p>
    <h2 id="testimonials-title" class="mt-2 text-2xl font-bold tracking-[-0.03em] md:text-3xl">What engineers are saying</h2>
    <p class="mt-4 max-w-3xl text-[var(--color-text-secondary)]">From the people building and using Ace.</p>

    <ul class="mt-8 grid list-none gap-6 p-0 md:grid-cols-3" aria-label="User testimonials">
      {
        testimonials.map((t) => (
          <li class="m-0">
            <blockquote class:list={[
              "grid h-full gap-4 rounded-[var(--radius-lg)] border border-[var(--color-stroke-subtle)] border-l-2 bg-[var(--color-surface)] p-6",
              t.placeholder ? "border-l-[var(--color-stroke-strong)] border-dashed" : "border-l-[var(--color-primary)]",
            ]}>
              <p class:list={[
                "m-0 text-sm leading-relaxed",
                t.placeholder ? "text-[var(--color-text-muted)] italic" : "text-[var(--color-text-secondary)]",
              ]}>{t.placeholder ? t.quote : <Fragment>&ldquo;{t.quote}&rdquo;</Fragment>}</p>
              <footer class="mt-auto">
                <cite class="not-italic">
                  <span class="block text-sm font-semibold text-[var(--color-text-primary)]">{t.name}</span>
                  <span class="block text-xs text-[var(--color-text-muted)]">{t.role}</span>
                </cite>
              </footer>
            </blockquote>
          </li>
        ))
      }
    </ul>
  </div>
</section>
