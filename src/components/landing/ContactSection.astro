---
const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '1x00000000000000000000AA';
---

<section id="contact" class="section-band alt-section" aria-labelledby="contact-title">
  <div class="section-inner max-w-2xl">
    <p class="m-0 font-[family-name:var(--font-mono)] text-xs uppercase tracking-[0.06em] text-[var(--color-primary)]">Contact</p>
    <h2 id="contact-title" class="mt-2 text-2xl font-bold tracking-[-0.03em] md:text-3xl">Get in touch</h2>
    <p class="mt-4 text-[var(--color-text-secondary)]">
      Questions about Ace? Want to contribute or partner? Drop us a message.
    </p>

    <form id="contact-form" class="mt-8 grid gap-4" action="/api/contact" method="POST">
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <label for="contact-name" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Name</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            autocomplete="name"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-stroke-strong)] bg-[var(--color-surface)] px-3 py-2.5 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-disabled)] outline-none transition focus:border-[var(--color-primary)] focus:shadow-[var(--shadow-focus)]"
            placeholder="Your name"
          />
        </div>
        <div>
          <label for="contact-email" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            autocomplete="email"
            class="w-full rounded-[var(--radius-md)] border border-[var(--color-stroke-strong)] bg-[var(--color-surface)] px-3 py-2.5 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-disabled)] outline-none transition focus:border-[var(--color-primary)] focus:shadow-[var(--shadow-focus)]"
            placeholder="you@company.com"
          />
        </div>
      </div>

      <div>
        <label for="contact-subject" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Subject</label>
        <input
          type="text"
          id="contact-subject"
          name="subject"
          required
          class="w-full rounded-[var(--radius-md)] border border-[var(--color-stroke-strong)] bg-[var(--color-surface)] px-3 py-2.5 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-disabled)] outline-none transition focus:border-[var(--color-primary)] focus:shadow-[var(--shadow-focus)]"
          placeholder="What's this about?"
        />
      </div>

      <div>
        <label for="contact-message" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Message</label>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="5"
          class="w-full resize-y rounded-[var(--radius-md)] border border-[var(--color-stroke-strong)] bg-[var(--color-surface)] px-3 py-2.5 text-sm text-[var(--color-text-primary)] placeholder-[var(--color-text-disabled)] outline-none transition focus:border-[var(--color-primary)] focus:shadow-[var(--shadow-focus)]"
          placeholder="Your message..."
        ></textarea>
      </div>

      <!-- Honeypot — hidden from real users, bots fill it -->
      <div style="position: absolute; left: -9999px;" aria-hidden="true">
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>

      <!-- Cloudflare Turnstile -->
      <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>

      <div class="flex items-center gap-4">
        <button
          type="submit"
          id="contact-submit"
          class="btn-primary"
        >
          Send message
        </button>
        <p id="contact-status" class="m-0 text-sm hidden"></p>
      </div>
    </form>
  </div>
</section>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script is:inline>
  (function() {
    var form = document.getElementById('contact-form');
    var status = document.getElementById('contact-status');
    var btn = document.getElementById('contact-submit');

    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      btn.disabled = true;
      btn.textContent = 'Sending...';
      status.className = 'm-0 text-sm hidden';

      var data = new FormData(form);

      fetch('/api/contact', {
        method: 'POST',
        body: data,
      })
        .then(function(res) { return res.json(); })
        .then(function(result) {
          if (result.success) {
            status.textContent = 'Message sent. We\'ll get back to you soon.';
            status.className = 'm-0 text-sm text-[var(--color-secondary)]';
            form.reset();
            // Reset turnstile
            if (window.turnstile) window.turnstile.reset();
          } else {
            status.textContent = result.error || 'Something went wrong. Try again.';
            status.className = 'm-0 text-sm text-[var(--color-error)]';
          }
        })
        .catch(function() {
          status.textContent = 'Network error. Please try again.';
          status.className = 'm-0 text-sm text-[var(--color-error)]';
        })
        .finally(function() {
          btn.disabled = false;
          btn.textContent = 'Send message';
        });
    });
  })();
</script>
